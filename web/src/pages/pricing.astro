---
import MainLayout from '../layouts/MainLayout.astro';
import Footer from '../components/astro/Footer.astro';
import { pricingPlans } from '../lib/landingData.js';

const title = 'Pricing — DecoDocs';
const description =
  'Compare DecoDocs plans for individuals and teams. Start free, then upgrade when you need OCR, storage, and team controls.';

const formatAud = (value) => {
  try {
    return new Intl.NumberFormat('en-AU', {
      style: 'currency',
      currency: 'AUD',
      maximumFractionDigits: 0,
    }).format(value);
  } catch {
    return `$${value} AUD`;
  }
};

const buildUpgradeHref = (plan, billing) =>
  `/sign-in?intent=upgrade&plan=${encodeURIComponent(plan)}&billing=${encodeURIComponent(billing)}`;
---

<MainLayout
  title={title}
  description={description}
  canonical="https://decodocs.com/pricing/"
  image="https://decodocs.com/og.svg"
>
  <main class="relative overflow-hidden px-6 pb-20 pt-14 lg:pt-20">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -right-20 -top-16 h-72 w-72 rounded-full bg-[#d8e6ff] opacity-60 blur-3xl" />
      <div class="absolute -left-20 top-44 h-72 w-72 rounded-full bg-[#fde4c7] opacity-50 blur-3xl" />
    </div>

    <section class="relative mx-auto w-full max-w-6xl">
      <div class="rounded-3xl border border-slate-200/80 bg-white/85 p-8 shadow-xl shadow-slate-900/5 backdrop-blur-sm lg:p-12">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-slate-500">Pricing</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 lg:text-5xl">
          Plans for clear document decisions
        </h1>
        <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-600">
          Start with anonymous trial mode, then upgrade when you need OCR support, larger analysis budgets, storage,
          and team workflows.
        </p>
      </div>
    </section>

    <section class="relative mx-auto mt-8 grid w-full max-w-6xl gap-4 md:grid-cols-2 xl:grid-cols-3">
      {pricingPlans.map((plan) => {
        const isFree = plan.monthlyPrice === 0 && plan.annualPrice === 0;
        const planSlug = plan.name.toLowerCase();
        return (
          <article
            class={`rounded-3xl border bg-white p-6 shadow-lg shadow-slate-900/5 ${
              plan.isPopular ? 'border-slate-900 ring-1 ring-slate-900/10' : 'border-slate-200'
            }`}
          >
            {plan.isPopular ? (
              <span class="mb-3 inline-flex rounded-full border border-slate-900 bg-slate-900 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white">
                Popular
              </span>
            ) : null}
            <div class="flex items-baseline justify-between gap-2">
              <h2 class="text-xl font-black text-slate-900">{plan.name}</h2>
              <div class="text-right">
                <p class="text-2xl font-black text-slate-900">{formatAud(plan.monthlyPrice)}</p>
                <p class="text-xs font-semibold text-slate-500">monthly</p>
              </div>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{plan.description}</p>

            {isFree ? (
              <a
                href="/view"
                class="mt-5 inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-4 py-2.5 text-sm font-bold text-white no-underline transition hover:bg-slate-800"
              >
                {plan.cta}
              </a>
            ) : (
              <div class="mt-5 grid gap-2">
                <a
                  href={buildUpgradeHref(planSlug, 'monthly')}
                  class="inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-4 py-2.5 text-sm font-bold text-white no-underline transition hover:bg-slate-800"
                >
                  {plan.cta} (Monthly)
                </a>
                <a
                  href={buildUpgradeHref(planSlug, 'annual')}
                  class="inline-flex w-full items-center justify-center rounded-full border border-slate-300 bg-white px-4 py-2.5 text-sm font-bold text-slate-800 no-underline transition hover:bg-slate-50"
                >
                  {plan.cta} (Annual: {formatAud(plan.annualPrice)}/year)
                </a>
              </div>
            )}

            <ul class="mt-5 space-y-2 text-sm text-slate-700">
              {plan.highlights.map((highlight) => <li class="leading-relaxed">• {highlight}</li>)}
            </ul>
          </article>
        );
      })}
    </section>

    <section class="relative mx-auto mt-6 w-full max-w-6xl rounded-3xl border border-slate-200 bg-white p-7">
      <h2 class="text-lg font-black text-slate-900">Enterprise</h2>
      <p class="mt-2 text-sm leading-relaxed text-slate-600">
        Need more than 5 worker accounts, custom security controls, or procurement support? Contact us for seat-based
        enterprise pricing.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white no-underline hover:bg-slate-800"
        >
          Contact sales
        </a>
        <a
          href="/terms"
          class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-2.5 text-sm font-semibold text-slate-800 no-underline hover:bg-slate-50"
        >
          Terms
        </a>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>
